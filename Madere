// ════════════════════════════════
// STATE
// ════════════════════════════════
let prenom = localStorage.getItem('madere_prenom') || null;
let allVotes = [];
let pollTimer = null;

// ════════════════════════════════
// IDENTITY
// ════════════════════════════════
function setPrenom() {
  const v = document.getElementById('prenomInput').value.trim();
  if (!v) { document.getElementById('prenomInput').focus(); return; }
  prenom = v;
  localStorage.setItem('madere_prenom', v);
  document.getElementById('modalOverlay').classList.add('hidden');
  document.getElementById('userPill').classList.remove('hidden');
  document.getElementById('pillName').textContent = v;
  loadVotes();
}
function changeUser() {
  document.getElementById('prenomInput').value = '';
  document.getElementById('modalOverlay').classList.remove('hidden');
}
document.getElementById('prenomInput').addEventListener('keydown', e => { if (e.key==='Enter') setPrenom(); });

// Init modal
if (prenom) {
  document.getElementById('modalOverlay').classList.add('hidden');
  document.getElementById('userPill').classList.remove('hidden');
  document.getElementById('pillName').textContent = prenom;
  loadVotes();
}

// ════════════════════════════════
// SUPABASE LOAD
// ════════════════════════════════
async function loadVotes() {
  try {
    const rows = await sbFetch('/rest/v1/votes?select=slot_id,prenom,choice&order=created_at.asc');
    allVotes = rows;

    // Suggest existing names in modal
    const names = [...new Set(rows.map(r => r.prenom))].slice(0, 12);
    if (names.length) {
      document.getElementById('modalNames').innerHTML =
        `<span class="modal-names-label">Déjà présents</span>` +
        names.map(n => `<span class="name-chip" onclick="quickJoin('${n}')">${n}</span>`).join('');
    }

    renderAll();

    if (!pollTimer) {
      pollTimer = setInterval(async () => {
        try {
          const fresh = await sbFetch('/rest/v1/votes?select=slot_id,prenom,choice&order=created_at.asc');
          allVotes = fresh;
          renderAll();
        } catch(e) { /* silent */ }
      }, 6000);
    }
  } catch(e) {
    console.error(e);
    document.getElementById('slotsArea').innerHTML =
      `<div class="loading-spinner" style="color:#e8967a">
        Erreur de connexion. Vérifiez que la table "votes" existe dans Supabase.<br><br>
        <span style="font-size:.7rem;opacity:.6">Voir le fichier supabase-setup.sql fourni.</span>
      </div>`;
  }
}

function quickJoin(name) {
  document.getElementById('prenomInput').value = name;
  setPrenom();
}

// ════════════════════════════════
// VOTE ACTION
// ════════════════════════════════
async function vote(slotId, choice) {
  if (!prenom) return;
  const existing = allVotes.find(v => v.slot_id===slotId && v.prenom===prenom);

  if (existing && existing.choice === choice) {
    // Toggle off
    allVotes = allVotes.filter(v => !(v.slot_id===slotId && v.prenom===prenom));
    renderAll();
    try {
      await sbFetch(`/rest/v1/votes?slot_id=eq.${slotId}&prenom=eq.${encodeURIComponent(prenom)}`, { method:'DELETE', headers:{'Prefer':''} });
    } catch(e) { console.error(e); }
  } else {
    if (existing) existing.choice = choice;
    else allVotes.push({ slot_id:slotId, prenom, choice });
    renderAll();
    try {
      await sbFetch('/rest/v1/votes', {
        method:'POST',
        headers:{ 'Prefer':'resolution=merge-duplicates,return=minimal' },
        body: JSON.stringify({ slot_id:slotId, prenom, choice })
      });
    } catch(e) { console.error(e); }
  }
}

// ════════════════════════════════
// SCORING
// ════════════════════════════════
function summary(slotId) {
  const sv = allVotes.filter(v => v.slot_id===slotId);
  return {
    yes:   sv.filter(v=>v.choice==='yes'),
    maybe: sv.filter(v=>v.choice==='maybe'),
    no:    sv.filter(v=>v.choice==='no'),
    mine:  sv.find(v=>v.prenom===prenom)?.choice || null,
    total: sv.length
  };
}
function score(slotId) {
  const s = summary(slotId);
  return s.yes.length*3 + s.maybe.length*1 - s.no.length*2;
}
function winner(dayId) {
  const ds = SLOTS.filter(s=>s.dayId===dayId);
  const withVotes = ds.filter(s=>summary(s.id).total>0);
  if (!withVotes.length) return null;
  const sorted = [...withVotes].sort((a,b)=>score(b.id)-score(a.id));
  return score(sorted[0].id) > 0 ? sorted[0] : null;
}

// ════════════════════════════════
// RENDER
// ════════════════════════════════
function renderAll() {
  renderSlots();
  renderRetained();
}

function renderSlots() {
  const area = document.getElementById('slotsArea');
  area.innerHTML = '';

  DAYS.forEach(day => {
    const ds = SLOTS.filter(s=>s.dayId===day.id);
    const w = winner(day.id);

    const block = document.createElement('div');
    block.className = 'day-block';
    block.innerHTML = `<p class="day-label">${day.label}</p>`;
    const row = document.createElement('div');
    row.className = 'slots-row';

    ds.forEach(slot => {
      const { yes, maybe, no, mine, total } = summary(slot.id);
      const isWin = w && w.id===slot.id;
      const pY = total ? Math.round(yes.length/total*100) : 0;
      const pM = total ? Math.round(maybe.length/total*100) : 0;
      const pN = total ? Math.round(no.length/total*100) : 0;

      const chips = [
        ...yes.map(v=>`<span class="who-chip yes">${v.prenom} 👍</span>`),
        ...maybe.map(v=>`<span class="who-chip maybe">${v.prenom} 🤔</span>`),
        ...no.map(v=>`<span class="who-chip no">${v.prenom} 👎</span>`),
      ].join('');

      const card = document.createElement('div');
      card.className = 'slot' + (isWin ? ' winner' : '');
      card.innerHTML = `
        <span class="assigned-badge">✓ Retenu</span>
        <img class="slot-photo" src="${slot.photo}" alt="${slot.name}" loading="lazy"
          onerror="this.style.display='none'">
        <div class="slot-body">
          <p class="slot-cat">${slot.cat}</p>
          <h3 class="slot-name">${slot.name}</h3>
          <p class="slot-desc">${slot.desc}</p>
          <div class="slot-tags">${slot.tags.map(t=>`<span class="stag ${t.c}">${t.l}</span>`).join('')}</div>
          <div class="vote-section">
            <p class="vote-label">Votre avis</p>
            <div class="vote-btns">
              <button class="vote-btn yes ${mine==='yes'?'active':''}" onclick="vote('${slot.id}','yes')">
                👍 Pour <span class="vote-count">${yes.length}</span>
              </button>
              <button class="vote-btn maybe ${mine==='maybe'?'active':''}" onclick="vote('${slot.id}','maybe')">
                🤔 Peut-être <span class="vote-count">${maybe.length}</span>
              </button>
              <button class="vote-btn no ${mine==='no'?'active':''}" onclick="vote('${slot.id}','no')">
                👎 Non <span class="vote-count">${no.length}</span>
              </button>
            </div>
            <div class="vote-bar">
              <div class="vbar-yes" style="width:${pY}%"></div>
              <div class="vbar-maybe" style="width:${pM}%"></div>
              <div class="vbar-no" style="width:${pN}%"></div>
            </div>
            <div class="who-voted">
              ${chips || '<span class="no-votes-yet">Pas encore de votes</span>'}
            </div>
          </div>
        </div>`;
      row.appendChild(card);
    });

    block.appendChild(row);
    area.appendChild(block);
  });
}

function renderRetained() {
  const grid = document.getElementById('retainedGrid');
  grid.innerHTML = '';

  // Arrivée fixe
  addFixed(grid,'Lun',3,'#c0392b',
    'https://upload.wikimedia.org/wikipedia/commons/thumb/3/3e/Funchal_Hafen.jpg/160px-Funchal_Hafen.jpg',
    'Arrivée à Funchal ✈️','Vol, voitures, installation. Premier dîner de groupe ensemble.');

  DAYS.forEach(day => {
    const w = winner(day.id);
    const row = document.createElement('div');
    row.className = 'ret-row';
    if (w) {
      row.innerHTML = `
        <div class="ret-date">
          <span class="ret-dow">${day.dow}</span>
          <span class="ret-day">${day.day}</span>
          <span class="ret-mon">Août</span>
        </div>
        <div class="ret-body">
          <img class="ret-thumb" src="${w.photo}" alt="${w.name}" onerror="this.style.display='none'">
          <div><p class="ret-title">${w.name}</p><p class="ret-desc">${w.desc.slice(0,110)}…</p></div>
        </div>`;
    } else {
      row.innerHTML = `
        <div class="ret-date" style="background:#2a4a5a">
          <span class="ret-dow">${day.dow}</span>
          <span class="ret-day">${day.day}</span>
          <span class="ret-mon">Août</span>
        </div>
        <div class="ret-body ret-pending">En attente de votes…</div>`;
    }
    grid.appendChild(row);
  });

  // Départ fixe
  addFixed(grid,'Lun',10,'#c0392b',null,
    'Marché de Funchal & départ ✈️',
    'Mercado dos Lavradores pour les derniers achats. Retour.');
}

function addFixed(grid, dow, day, bg, thumb, title, desc) {
  const row = document.createElement('div');
  row.className = 'ret-row';
  row.innerHTML = `
    <div class="ret-date" style="background:${bg}">
      <span class="ret-dow">${dow}</span><span class="ret-day">${day}</span><span class="ret-mon">Août</span>
    </div>
    <div class="ret-body">
      ${thumb ? `<img class="ret-thumb" src="${thumb}" onerror="this.style.display='none'">` : ''}
      <div><p class="ret-title">${title}</p><p class="ret-desc">${desc}</p></div>
    </div>`;
  grid.appendChild(row);
}
