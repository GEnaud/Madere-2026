<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Madère · Août 2025 · Programme</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400;1,700&family=Lato:wght@300;400;700&display=swap" rel="stylesheet">
<style>
* { margin:0; padding:0; box-sizing:border-box; }
:root {
  --ocean:#1b4f72; --deep:#0e2a38; --lava:#c0392b;
  --sun:#d4a017; --sand:#f5ede0; --green:#1e8449;
  --mist:#aed6f1; --white:#fdfaf6; --text:#1a2a35; --mid:#5a7a8a;
}
body { font-family:'Lato',sans-serif; background:var(--deep); color:var(--white); }

/* ── MODAL ── */
.modal-overlay {
  position:fixed; inset:0; background:rgba(14,42,56,.97);
  z-index:1000; display:flex; align-items:center; justify-content:center; padding:1.5rem;
}
.modal-overlay.hidden { display:none; }
.modal-box {
  background:rgba(27,79,114,.25); border:1px solid rgba(255,255,255,.12);
  padding:2.5rem; max-width:420px; width:100%; text-align:center; border-radius:4px;
}
.modal-title { font-family:'Playfair Display',serif; font-size:2rem; font-weight:400; margin-bottom:.5rem; }
.modal-title em { font-style:italic; color:var(--sun); }
.modal-sub { font-size:.85rem; color:rgba(255,255,255,.5); font-weight:300; margin-bottom:2rem; line-height:1.7; }
.modal-input {
  width:100%; background:rgba(255,255,255,.07); border:1px solid rgba(255,255,255,.2);
  color:var(--white); font-family:'Lato',sans-serif; font-size:1rem;
  padding:.9rem 1.2rem; outline:none; margin-bottom:1rem; border-radius:2px;
}
.modal-input:focus { border-color:var(--sun); }
.modal-btn {
  width:100%; background:var(--ocean); color:var(--white); border:none;
  font-family:'Lato',sans-serif; font-size:.85rem; letter-spacing:.15em;
  text-transform:uppercase; padding:1rem; cursor:pointer; transition:background .2s; border-radius:2px;
}
.modal-btn:hover { background:#1f5f8a; }
.modal-names { margin-top:1.5rem; }
.modal-names-label { font-size:.65rem; letter-spacing:.15em; text-transform:uppercase; color:rgba(255,255,255,.3); margin-bottom:.6rem; display:block; }
.name-chip {
  display:inline-block; margin:.2rem .25rem; padding:.3rem .8rem;
  border:1px solid rgba(255,255,255,.15); border-radius:20px;
  font-size:.75rem; cursor:pointer; transition:all .15s; color:rgba(255,255,255,.6);
}
.name-chip:hover { border-color:var(--sun); color:var(--sun); }

/* ── USER PILL ── */
.user-pill {
  position:fixed; top:1rem; right:1rem; z-index:200;
  background:rgba(14,42,56,.92); border:1px solid rgba(255,255,255,.15);
  padding:.4rem 1rem; border-radius:20px; font-size:.75rem;
  display:flex; align-items:center; gap:.6rem; cursor:pointer; backdrop-filter:blur(4px);
}
.user-pill .dot { width:8px; height:8px; border-radius:50%; background:var(--green); flex-shrink:0; }
.user-pill.hidden { display:none; }

/* ── HERO ── */
.hero {
  position:relative; height:100vh; min-height:500px;
  display:flex; flex-direction:column; align-items:center; justify-content:center;
  text-align:center; overflow:hidden;
}
.hero-img {
  position:absolute; inset:0;
  background:url('https://upload.wikimedia.org/wikipedia/commons/thumb/a/ae/20190520_Madeira_Ponta_de_S%C3%A3o_Louren%C3%A7o_1310_5484.jpg/1280px-20190520_Madeira_Ponta_de_S%C3%A3o_Louren%C3%A7o_1310_5484.jpg') center/cover no-repeat;
  filter:brightness(.3);
}
.hero-overlay { position:absolute; inset:0; background:linear-gradient(to bottom,rgba(14,42,56,.1),rgba(14,42,56,.85)); }
.hero-content { position:relative; z-index:2; padding:2rem; }
.hero-eyebrow { font-size:.65rem; letter-spacing:.35em; text-transform:uppercase; color:var(--sun); margin-bottom:1.2rem; font-weight:300; }
.hero-title { font-family:'Playfair Display',serif; font-size:clamp(3.5rem,10vw,8rem); font-weight:400; line-height:.95; margin-bottom:1.2rem; }
.hero-title em { font-style:italic; color:var(--sun); }
.hero-sub { font-size:clamp(.9rem,2vw,1.1rem); font-weight:300; color:rgba(255,255,255,.75); max-width:540px; line-height:1.7; }
.hero-chips { display:flex; gap:.75rem; flex-wrap:wrap; justify-content:center; margin-top:2rem; }
.chip { font-size:.6rem; letter-spacing:.2em; text-transform:uppercase; border:1px solid rgba(255,255,255,.3); padding:.35rem .9rem; border-radius:2px; color:rgba(255,255,255,.7); }
.hero-scroll { position:absolute; bottom:2rem; left:50%; transform:translateX(-50%); display:flex; flex-direction:column; align-items:center; gap:.5rem; cursor:pointer; z-index:2; }
.hero-scroll span { font-size:.55rem; letter-spacing:.3em; text-transform:uppercase; opacity:.5; }
.scroll-arrow { width:1px; height:40px; background:linear-gradient(to bottom,rgba(255,255,255,.6),transparent); animation:pulse 2s infinite; }
@keyframes pulse{0%,100%{opacity:.3}50%{opacity:1}}

/* ── INTRO ── */
.intro { background:var(--white); color:var(--text); padding:4rem 2rem; text-align:center; }
.intro-title { font-family:'Playfair Display',serif; font-size:clamp(1.8rem,4vw,2.8rem); font-weight:400; margin-bottom:1rem; }
.intro-title em { font-style:italic; color:var(--lava); }
.intro-body { max-width:620px; margin:0 auto; font-size:1rem; font-weight:300; line-height:1.8; color:#4a6070; }
.vote-legend { display:flex; gap:1.5rem; flex-wrap:wrap; justify-content:center; margin-top:2rem; }
.legend-item { display:flex; align-items:center; gap:.5rem; font-size:.8rem; color:#4a6070; }
.legend-dot { width:10px; height:10px; border-radius:50%; }

/* ── DAYS HEADER ── */
.days-header { background:var(--deep); padding:3rem 2rem 0; text-align:center; }
.days-header h2 { font-family:'Playfair Display',serif; font-size:clamp(1.5rem,3vw,2rem); font-weight:400; margin-bottom:.5rem; }
.days-header p { font-size:.85rem; color:rgba(255,255,255,.5); font-weight:300; }

/* ── SLOTS ── */
.slots-wrapper { background:var(--deep); padding:2rem 1rem 3rem; }
.day-block { margin-bottom:3rem; }
.day-label { font-size:.6rem; letter-spacing:.3em; text-transform:uppercase; color:var(--sun); font-weight:700; padding:0 .5rem 1rem; }
.slots-row {
  display:grid; grid-template-columns:repeat(auto-fill,minmax(280px,1fr));
  gap:1px; background:rgba(255,255,255,.08);
  border:1px solid rgba(255,255,255,.08); border-radius:4px; overflow:hidden;
}
.slot { background:rgba(14,42,56,.95); position:relative; overflow:hidden; }
.slot-photo { width:100%; height:170px; object-fit:cover; display:block; filter:brightness(.8); transition:filter .3s,transform .3s; }
.slot:hover .slot-photo { filter:brightness(.95); transform:scale(1.02); }
.slot-body { padding:1rem 1.25rem 1.25rem; }
.slot-cat { font-size:.55rem; letter-spacing:.2em; text-transform:uppercase; color:var(--sun); font-weight:700; margin-bottom:.4rem; }
.slot-name { font-family:'Playfair Display',serif; font-size:1.15rem; font-weight:400; margin-bottom:.4rem; line-height:1.25; }
.slot-desc { font-size:.8rem; font-weight:300; color:rgba(255,255,255,.6); line-height:1.65; margin-bottom:.9rem; }
.slot-tags { display:flex; flex-wrap:wrap; gap:.4rem; margin-bottom:1rem; }
.stag { font-size:.55rem; letter-spacing:.1em; text-transform:uppercase; padding:.2rem .5rem; border-radius:2px; border:1px solid rgba(255,255,255,.2); color:rgba(255,255,255,.5); }
.stag.water { border-color:rgba(174,214,241,.4); color:#aed6f1; }
.stag.hike  { border-color:rgba(30,132,73,.5); color:#82e0aa; }
.stag.fun   { border-color:rgba(192,57,43,.4); color:#e8967a; }
.stag.chill { border-color:rgba(255,255,255,.2); }
.stag.cult  { border-color:rgba(212,160,23,.4); color:var(--sun); }

/* ── VOTE ── */
.vote-section { border-top:1px solid rgba(255,255,255,.08); padding-top:.75rem; }
.vote-label { font-size:.6rem; letter-spacing:.15em; text-transform:uppercase; color:rgba(255,255,255,.35); margin-bottom:.5rem; }
.vote-btns { display:flex; gap:.4rem; }
.vote-btn {
  flex:1; padding:.5rem .3rem; border:1px solid rgba(255,255,255,.15);
  background:none; color:rgba(255,255,255,.6); font-family:'Lato',sans-serif;
  font-size:.68rem; cursor:pointer; border-radius:2px; transition:all .15s;
  display:flex; align-items:center; justify-content:center; gap:.3rem;
}
.vote-btn:hover { background:rgba(255,255,255,.08); }
.vote-btn.yes.active   { background:rgba(30,132,73,.25);   border-color:var(--green); color:#82e0aa; }
.vote-btn.maybe.active { background:rgba(212,160,23,.15);  border-color:var(--sun);   color:var(--sun); }
.vote-btn.no.active    { background:rgba(192,57,43,.15);   border-color:var(--lava);  color:#e8967a; }
.vote-count { font-size:.6rem; opacity:.7; }
.vote-bar { height:3px; margin-top:.6rem; border-radius:1px; overflow:hidden; display:flex; }
.vbar-yes   { background:var(--green); transition:width .4s; }
.vbar-maybe { background:var(--sun);   transition:width .4s; }
.vbar-no    { background:var(--lava);  transition:width .4s; }
.who-voted { margin-top:.6rem; display:flex; flex-wrap:wrap; gap:.3rem; min-height:20px; }
.who-chip { font-size:.6rem; padding:.2rem .55rem; border-radius:10px; font-weight:700; }
.who-chip.yes   { background:rgba(30,132,73,.3);  color:#82e0aa; }
.who-chip.maybe { background:rgba(212,160,23,.2); color:var(--sun); }
.who-chip.no    { background:rgba(192,57,43,.2);  color:#e8967a; }
.no-votes-yet { font-size:.65rem; opacity:.3; font-style:italic; }

/* ── WINNER BADGE ── */
.assigned-badge {
  position:absolute; top:.6rem; right:.6rem; font-size:.55rem; letter-spacing:.12em;
  text-transform:uppercase; padding:.25rem .65rem; border-radius:2px;
  background:rgba(30,132,73,.9); color:#fff; font-weight:700; display:none;
}
.slot.winner { outline:2px solid var(--green); }
.slot.winner .assigned-badge { display:block; }

/* ── LOADING ── */
.loading-spinner { text-align:center; padding:3rem; font-size:.8rem; color:rgba(255,255,255,.35); letter-spacing:.2em; text-transform:uppercase; }

/* ── RETAINED ── */
.retained { background:var(--sand); color:var(--text); padding:4rem 2rem; }
.retained h2 { font-family:'Playfair Display',serif; font-size:clamp(1.8rem,4vw,2.5rem); font-weight:400; text-align:center; margin-bottom:.5rem; }
.retained h2 em { font-style:italic; color:var(--lava); }
.retained-sub { text-align:center; font-size:.85rem; color:var(--mid); margin-bottom:2.5rem; font-weight:300; }
.retained-grid { display:grid; gap:.75rem; max-width:900px; margin:0 auto; }
.ret-row { display:grid; grid-template-columns:90px 1fr; background:var(--white); border-left:3px solid var(--ocean); overflow:hidden; }
.ret-date { background:var(--ocean); color:var(--white); display:flex; flex-direction:column; align-items:center; justify-content:center; padding:.75rem; text-align:center; }
.ret-dow { font-size:.55rem; letter-spacing:.2em; text-transform:uppercase; opacity:.7; }
.ret-day { font-family:'Playfair Display',serif; font-size:1.8rem; line-height:1; }
.ret-mon { font-size:.6rem; letter-spacing:.1em; text-transform:uppercase; opacity:.7; }
.ret-body { padding:.75rem 1rem; display:flex; align-items:center; gap:1rem; }
.ret-thumb { width:56px; height:56px; object-fit:cover; border-radius:2px; flex-shrink:0; }
.ret-title { font-family:'Playfair Display',serif; font-size:1rem; margin-bottom:.2rem; }
.ret-desc { font-size:.75rem; color:var(--mid); font-weight:300; line-height:1.5; }
.ret-pending { color:var(--mid); font-style:italic; font-size:.85rem; }

/* ── PRACTICAL ── */
.practical { background:var(--deep); padding:4rem 2rem; }
.practical-inner { max-width:900px; margin:0 auto; }
.practical h2 { font-family:'Playfair Display',serif; font-size:clamp(1.5rem,3vw,2rem); font-weight:400; margin-bottom:2rem; text-align:center; }
.practical h2 em { font-style:italic; color:var(--sun); }
.prac-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(250px,1fr)); gap:1px; background:rgba(255,255,255,.08); border:1px solid rgba(255,255,255,.08); }
.pcard { background:rgba(14,42,56,.9); padding:1.5rem; }
.pcard-title { font-size:.6rem; letter-spacing:.2em; text-transform:uppercase; color:var(--sun); margin-bottom:1rem; font-weight:700; }
.pcard ul { list-style:none; font-size:.85rem; font-weight:300; line-height:2; color:rgba(255,255,255,.65); }
.pcard li::before { content:'— '; color:var(--lava); }

footer { background:rgba(0,0,0,.4); text-align:center; padding:1.5rem; font-size:.65rem; letter-spacing:.15em; color:rgba(255,255,255,.3); text-transform:uppercase; }

@media(max-width:600px){
  .slots-row { grid-template-columns:1fr; }
  .ret-row { grid-template-columns:70px 1fr; }
  .ret-day { font-size:1.4rem; }
  .vote-btn { font-size:.62rem; }
}
</style>
</head>
